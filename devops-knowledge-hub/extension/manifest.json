{
  "manifest_version": 3,
  "name": "DevOps Knowledge Hub",
  "version": "1.1.0",
  "description": "Save LinkedIn documents to your local DevOps Knowledge Hub",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://media.licdn.com/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
